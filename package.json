{
	"name": "svelte-unstyled-tags",
	"description": "An unstyled Svelte component for handling tags input with customisable features (add, remove, clear tags) and styling options.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/edjw/svelte-unstyled-tags.git"
	},
	"keywords": [
		"svelte",
		"tags",
		"component",
		"tag-input",
		"form-component",
		"svelte-component",
		"input-tags",
		"UI-component",
		"input-fields"
	],
	"version": "0.1.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint",
		"prepublishOnly": "npm run package",
		"test": "playwright test",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"peerDependencies": {
		"svelte": "^5.20.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.28.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"prettier": "^3.0.0",
		"prettier-plugin-svelte": "^4.1.1",
		"publint": "^0.3.21",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tslib": "^2.4.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.0.16"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module"
}
